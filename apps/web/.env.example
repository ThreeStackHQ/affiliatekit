# Database
DATABASE_URL="postgresql://user:password@localhost:5432/affiliatekit"

# NextAuth
AUTH_SECRET="your-auth-secret-min-32-chars-here"
NEXTAUTH_URL="http://localhost:3000"

# GitHub OAuth
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# App URL (used for generating affiliate links)
NEXT_PUBLIC_APP_URL="https://your-site.com"

# Encryption key for storing secrets (AES-256-GCM)
ENCRYPTION_KEY="your-32-char-encryption-key-here!"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
